@echo off
setlocal EnableExtensions
title Linear Algebra Quiz - JavaScript Editor

set "SELF=%~f0"
set "TEMP_PS1=%TEMP%\LAQuiz_%RANDOM%_%RANDOM%.ps1"

powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "$lines=[IO.File]::ReadAllLines($env:SELF); $marker=[Array]::IndexOf($lines,'::LAQUIZ_PAYLOAD'); if($marker -lt 0){exit 10}; $b64=($lines[($marker+1)..($lines.Length-1)] -join ''); [IO.File]::WriteAllBytes($env:TEMP_PS1,[Convert]::FromBase64String($b64))"
if errorlevel 1 (
    echo.
    echo This standalone tool could not unpack its PowerShell program.
    echo.
    pause
    exit /b 1
)

