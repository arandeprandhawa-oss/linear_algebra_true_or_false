set "EXIT_CODE=%ERRORLEVEL%"

del /q "%TEMP_PS1%" >nul 2>&1

if not "%EXIT_CODE%"=="0" (
    echo.
    echo The tool ended with an error.
    pause
)

exit /b %EXIT_CODE%

